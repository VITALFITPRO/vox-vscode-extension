{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vox (Português)",
  "scopeName": "source.vox.pt",
  "patterns": [
    { "name": "comment.line.double-slash.vox", "match": "//.*$" },
    { "name": "comment.block.vox", "begin": "/\\*", "end": "\\*/" },
    { "name": "string.quoted.double.vox", "begin": "\"", "end": "\"" },
    { "name": "constant.numeric.vox", "match": "\\b\\d+(\\.\\d+)?\\b" },
    { "name": "constant.language.vox", "match": "\\b(verdadeiro|falso|nulo)\\b" },
    { "name": "keyword.declaration.vox", "match": "\\b(variavel|constante|funcao|classe|tela|construtor|importar|estado)\\b" },
    { "name": "keyword.control.vox", "match": "\\b(se|senao|enquanto|para|retornar|tentar|capturar|finalmente)\\b" },
    { "name": "keyword.other.vox", "match": "\\b(novo|este|estende|layout|ao_tocar|ao_mudar|imprimir)\\b" },
    { "name": "storage.type.vox", "match": "\\b(inteiro|decimal|texto|booleano|lista|objeto)\\b" },
    { "name": "entity.name.tag.widget.vox", "match": "\\b(Texto|Botao|Imagem|icone|coluna|linha|centro|container|preenchimento|espaco|pilha|entrada|lista|cartao|barra_app|flutuante|dialogo|carregando|divisor|interruptor|deslizador|suspenso|navegacao_inferior|avatar)\\b" }
  ]
}
