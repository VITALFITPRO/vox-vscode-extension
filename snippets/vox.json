{
  "Pantalla nueva": {
    "prefix": "pantalla",
    "body": [
      "pantalla ${1:Nombre} {",
      "  estado variable ${2:contador} = ${3:0};",
      "  funcion ${4:accion}() {",
      "    $5",
      "  }",
      "  diseño {",
      "    columna(alineacion: \"centro\") {",
      "      Texto(\"${6:Hola}\", tamaño: 24)",
      "      $0",
      "    }",
      "  }",
      "}"
    ],
    "description": "Crea una nueva pantalla Vox"
  },
  "Variable": {
    "prefix": "var",
    "body": ["variable ${1:nombre} = ${2:valor};"],
    "description": "Declara una variable"
  },
  "Funcion": {
    "prefix": "fun",
    "body": ["funcion ${1:nombre}(${2:params}) {", "  $0", "}"],
    "description": "Declara una función"
  },
  "Clase": {
    "prefix": "clase",
    "body": [
      "clase ${1:Nombre} {",
      "  variable ${2:propiedad};",
      "  constructor(${2:propiedad}) {",
      "    este.${2:propiedad} = ${2:propiedad};",
      "  }",
      "  funcion ${3:metodo}() {",
      "    $0",
      "  }",
      "}"
    ],
    "description": "Declara una clase"
  },
  "Si condicional": {
    "prefix": "si",
    "body": ["si (${1:condicion}) {", "  $0", "}"],
    "description": "Bloque condicional"
  },
  "Ir a Pantalla": {
    "prefix": "ira",
    "body": ["ir_a(\"${1:NombrePantalla}\");"],
    "description": "Navega a la pantalla solicitada"
  },
  "Regresar": {
    "prefix": "reg",
    "body": ["regresar();"],
    "description": "Regresa a la pantalla anterior"
  },
  "Navegacion Fila": {
    "prefix": "nav",
    "body": [
      "fila(alineacion: \"centro\") {",
      "  Boton(\"Regresar\", al_tocar: () {",
      "    regresar();",
      "  })",
      "  Boton(\"Avanzar\", al_tocar: () {",
      "    ir_a(\"${1:SiguientePantalla}\");",
      "  })",
      "}"
    ],
    "description": "Agrega botones básicos de ir_a y regresar"
  }
}
