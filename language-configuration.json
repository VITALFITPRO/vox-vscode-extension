{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [ ["{", "}"], ["[", "]"], ["(", ")"] ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [ ["{", "}"], ["[", "]"], ["(", ")"], ["\"", "\""] ],
  "wordPattern": "[a-zA-Z찼챕챠처첬챰횁횋횒횙횣횗체_][a-zA-Z찼챕챠처첬챰횁횋횒횙횣횗체0-9_]*"
}
